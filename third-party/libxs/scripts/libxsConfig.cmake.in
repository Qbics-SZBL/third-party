@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(LIBXS_VERSION "@PROJECT_VERSION@")
set(LIBXS_FORTRAN "@LIBXS_FORTRAN@")

find_dependency(Threads)

set_and_check(LIBXS_TARGETS_FILE "${CMAKE_CURRENT_LIST_DIR}/libxsTargets.cmake")
include("${LIBXS_TARGETS_FILE}")

check_required_components(libxs)
